<?xml version="1.0"?>
<!-- Define the location of the DTD -->
<!DOCTYPE geomodel SYSTEM "../geomodel.dtd" [
<!ENTITY materials SYSTEM "materials.gmx">
<!ENTITY definitions SYSTEM "definitions.xml">
]>
<geomodel xmlns="http://www.nikhef.nl/%7Er29/gmx" 
          name="LDMX_Detector_v14" version="14.0">
  <!-- Materials -->
  &materials;

  <!-- Defines --> 
  &definitions;

  <shapes>
    <box name="tagger_env_box" 
          xhalflength="tagger_env_dx/2" 
          yhalflength="tagger_env_dy/2" 
          zhalflength="tagger_env_dz/2"/>
    <box name="sensor_box" 
          xhalflength="sensor_dx/2" 
          yhalflength="sensor_dy/2" 
          zhalflength="si_sensor_thickness/2"/>
  </shapes>

  <logvol name="tagger_sensor" shape="sensor_box" material="SiMetal"/>
  <logvol name="tagger_env" shape="tagger_env_box" material="Air">
    <multicopy name="tagger_axial" n="7">
      <transformation name="tagger_axial_transform">
        <translation z="tagger_layer_delta" />
      </transformation>
      <transform>
        <transformation name="tagger_axial_shift" >
          <translation z="tagger_l7_axial_z" />
        </transformation>
        <logvolref ref="tagger_sensor" />
      </transform>
    </multicopy>
    <multicopy name="tagger_stereo" n="7">
      <transformation name="tagger_stereo_transform">
        <translation z="tagger_layer_delta" />
      </transformation>
      <transform>
        <transformation name="tagger_stereo_shift" >
          <translation z="tagger_l7_stereo_z" />
          <rotation zcos="1" angle="0.1" />
        </transformation>
        <logvolref ref="tagger_sensor" />
      </transform>
    </multicopy>
  </logvol>

  <assembly name="world">
    <transform>
      <transformation name="tagger_env_transform">
        <translation z="tagger_env_mid_z"/>
      </transformation>
      <logvolref ref="tagger_env"/>
    </transform>
  </assembly>

  <addbranch>
      <assemblyref ref="world" />
  </addbranch>

</geomodel>
