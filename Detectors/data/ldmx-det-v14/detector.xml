<?xml version="1.0"?>
<!-- Define the location of the DTD -->
<!DOCTYPE geomodel SYSTEM "../geomodel.dtd" [
<!ENTITY materials SYSTEM "materials.gmx">
<!ENTITY definitions SYSTEM "definitions.xml">
]>
<geomodel xmlns="http://www.nikhef.nl/%7Er29/gmx" 
          name="LDMX_Detector_v14" version="14.0">
  <!-- Materials -->
  &materials;

  <!-- Defines --> 
  &definitions;

  <shapes>
    <box name="tagger_env_box" 
          xhalflength="tagger_env_dx/2" 
          yhalflength="tagger_env_dy/2" 
          zhalflength="tagger_env_dz/2"/>
    <box name="sensor_box" 
          xhalflength="sensor_dx/2" 
          yhalflength="sensor_dy/2" 
          zhalflength="si_sensor_thickness/2"/>
  </shapes>

  <logvol name="tagger_sensor" shape="sensor_box" material="SiMetal"/>
  <logvol name="tagger_env" shape="tagger_env_box" material="Air">
      
      <transform>
          <transformation name="tagger_l1_axial_transformation">
            <translation x="tagger_l1_x" z="tagger_l1_mid_z - tagger_layer_offset" />
          </transformation>
          <logvolref ref="tagger_sensor" />
      </transform>
      <transform>
          <transformation name="tagger_l1_stereo_transformation">
            <translation x="tagger_l1_x" z="tagger_l1_mid_z + tagger_layer_offset" />
            <rotation zcos="1" angle="stereo_angle" />
          </transformation>
          <logvolref ref="tagger_sensor" />
      </transform>

      <transform>
          <transformation name="tagger_l2_axial_transformation">
            <translation x="tagger_l2_x" z="tagger_l2_mid_z - tagger_layer_offset" />
          </transformation>
          <logvolref ref="tagger_sensor" />
      </transform>
      <transform>
          <transformation name="tagger_l2_stereo_transformation">
            <translation x="tagger_l2_x" z="tagger_l2_mid_z + tagger_layer_offset" />
            <rotation zcos="1" angle="-1*stereo_angle" />
          </transformation>
          <logvolref ref="tagger_sensor" />
      </transform>

      <transform>
          <transformation name="tagger_l3_axial_transformation">
            <translation x="tagger_l3_x" z="tagger_l3_mid_z - tagger_layer_offset" />
          </transformation>
          <logvolref ref="tagger_sensor" />
      </transform>
      <transform>
          <transformation name="tagger_l3_stereo_transformation">
            <translation x="tagger_l3_x" z="tagger_l3_mid_z + tagger_layer_offset" />
            <rotation zcos="1" angle="stereo_angle" />
          </transformation>
          <logvolref ref="tagger_sensor" />
      </transform>

      <transform>
          <transformation name="tagger_l4_axial_transformation">
            <translation x="tagger_l4_x" z="tagger_l4_mid_z - tagger_layer_offset" />
          </transformation>
          <logvolref ref="tagger_sensor" />
      </transform>
      <transform>
          <transformation name="tagger_l4_stereo_transformation">
            <translation x="tagger_l4_x" z="tagger_l4_mid_z + tagger_layer_offset" />
            <rotation zcos="1" angle="-1*stereo_angle" />
          </transformation>
          <logvolref ref="tagger_sensor" />
      </transform>

      <transform>
          <transformation name="tagger_l5_axial_transformation">
            <translation x="tagger_l5_x" z="tagger_l5_mid_z - tagger_layer_offset" />
          </transformation>
          <logvolref ref="tagger_sensor" />
      </transform>
      <transform>
          <transformation name="tagger_l5_stereo_transformation">
            <translation x="tagger_l5_x" z="tagger_l5_mid_z + tagger_layer_offset" />
            <rotation zcos="1" angle="stereo_angle" />
          </transformation>
          <logvolref ref="tagger_sensor" />
      </transform>

      <transform>
          <transformation name="tagger_l6_axial_transformation">
            <translation x="tagger_l6_x" z="tagger_l6_mid_z - tagger_layer_offset" />
          </transformation>
          <logvolref ref="tagger_sensor" />
      </transform>
      <transform>
          <transformation name="tagger_l6_stereo_transformation">
            <translation x="tagger_l6_x" z="tagger_l6_mid_z + tagger_layer_offset" />
            <rotation zcos="1" angle="stereo_angle" />
          </transformation>
          <logvolref ref="tagger_sensor" />
      </transform>

      <transform>
          <transformation name="tagger_l7_axial_transformation">
            <translation x="tagger_l7_x" z="tagger_l7_mid_z - tagger_layer_offset" />
          </transformation>
          <logvolref ref="tagger_sensor" />
      </transform>
      <transform>
          <transformation name="tagger_l7_stereo_transformation">
            <translation x="tagger_l7_x" z="tagger_l7_mid_z + tagger_layer_offset" />
            <rotation zcos="1" angle="stereo_angle" />
          </transformation>
          <logvolref ref="tagger_sensor" />
      </transform>

  </logvol>

